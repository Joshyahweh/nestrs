  "keyFeatures": [
    "NestJS-style module/controller/provider architecture",
    "Attribute macros for HTTP routing (#[get], #[post], #[put], #[delete], etc.)",
    "Dependency injection with singleton, transient, and request scopes",
    "DTO validation pipeline with class-validator-style ergonomics",
    "Cross-cutting middleware: guards, pipes, interceptors, exception filters",
    "Built-in security: CORS, CSRF protection, security headers, rate limiting",
    "Observability: Prometheus metrics, distributed tracing, OpenTelemetry",
    "Microservice transports: Kafka, NATS, Redis, RabbitMQ, MQTT, gRPC",
    "Optional extensions: GraphQL, WebSockets, OpenAPI/Swagger UI",
    "CLI scaffold tool (nestrs-scaffold) for project and code generation",
    "API versioning (URI, header, media type)",
    "Prisma-style database integration via nestrs-prisma"
  ],
  "publicApiSurface": [
    "NestFactory::create::<M>()",
    "NestFactory::create_microservice::<M>(options)",
    "NestApplication::set_global_prefix()",
    "NestApplication::enable_cors(CorsOptions)",
    "NestApplication::use_security_headers(SecurityHeaders)",
    "NestApplication::use_rate_limit(RateLimitOptions)",
    "NestApplication::enable_metrics(path)",
    "NestApplication::enable_readiness_check(path, indicators)",
    "NestApplication::listen_graceful(port)",
    "#[module(controllers = [...], providers = [...])]",
    "#[controller(prefix = \"/path\")]",
    "#[routes(state = MyService)]",
    "#[get(\"/path\")], #[post], #[put], #[patch], #[delete]",
    "#[injectable], #[injectable(scope = \"request\")]",
    "#[dto] with #[IsString], #[IsEmail], #[Length], etc.",
    "#[use_guards(MyGuard)], #[use_pipes(MyPipe)], #[use_interceptors(MyInterceptor)]",
    "#[micro_routes], #[message_pattern], #[event_pattern]",
    "#[ws_gateway], #[ws_routes], #[subscribe_message]",
    "nestrs new <name> (CLI)",
    "nestrs generate resource <name> --transport rest|graphql|ws|grpc|microservice (CLI)",
    "nestrs doctor (CLI)"
  ]
}
