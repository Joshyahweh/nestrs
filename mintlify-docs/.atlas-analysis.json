  "keyFeatures": [
    "Module/controller/provider architecture mirroring NestJS patterns",
    "Procedural macros: #[module], #[controller], #[injectable], #[dto], HTTP route macros",
    "Dependency injection container with singleton, transient, and request scopes",
    "Cross-cutting pipeline: guards, pipes, interceptors, exception filters, strategies",
    "CLI scaffold tool (nestrs-scaffold) with nestrs new and nestrs generate commands",
    "Microservices transports: TCP, NATS, Redis, Kafka, MQTT, RabbitMQ, gRPC",
    "Extension crates: OpenAPI/Swagger UI, GraphQL, WebSockets",
    "Built-in middleware: CORS, rate limiting, security headers, request tracing, Prometheus metrics",
    "DTO validation pipeline with class-validator-style ergonomics",
    "API versioning (URI, header, media-type) and path normalization"
  ],
  "publicApiSurface": [
    "NestFactory::create::<M>()",
    "NestFactory::create_with_modules::<M, I>(dynamic_modules)",
    "NestFactory::create_microservice::<M>(options)",
    "NestApplication::set_global_prefix()",
    "NestApplication::enable_cors(CorsOptions)",
    "NestApplication::use_security_headers(SecurityHeaders)",
    "NestApplication::use_rate_limit(RateLimitOptions)",
    "NestApplication::enable_metrics(path)",
    "NestApplication::enable_readiness_check(path, indicators)",
    "NestApplication::enable_uri_versioning(version)",
    "NestApplication::listen_graceful(port)",
    "#[module(controllers = [...], providers = [...])]",
    "#[controller(prefix = \"...\")]",
    "#[injectable] / #[injectable(scope = \"...\")]",
    "#[dto] / #[dto(allow_unknown_fields)]",
    "#[get], #[post], #[put], #[patch], #[delete], #[options], #[head], #[all]",
    "#[routes(state = T)]",
    "#[use_guards(...)], #[use_pipes(...)], #[use_interceptors(...)]",
    "#[roles(...)], #[set_metadata(...)]",
    "nestrs generate resource|service|controller|module|dto|guard|pipe|filter|interceptor",
    "nestrs new <name>",
    "nestrs doctor",
    "ValidationPipe, ParseIntPipe",
    "ExceptionFilter trait",
    "CanActivate trait (guards)",
    "Interceptor trait",
    "PipeTransform trait",
    "HealthIndicator trait",
    "TestingModule / TestingModuleBuilder / TestClient"
  ]
}
