  "projectType": "framework",
  "projectName": "nestrs",
  "projectDescription": "A NestJS-like API framework for Rust built on Axum and Tower, providing modules, controllers, dependency injection, and a cross-cutting middleware pipeline.",
  "theme": "luma",
  "primaryColor": "#E94560",
  "lightColor": "#FF6B80",
